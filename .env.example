# Vite exposes only variables prefixed with VITE_ to browser code.

# API base URL for frontend requests.
# Local proxy mode can use /api/v1, direct local API can use http://127.0.0.1:8000/api/v1.
VITE_API_BASE_URL=/api/v1

# Environment marker for UI runtime/build diagnostics.
VITE_APP_ENV=dev

# Public application name displayed by the UI when needed.
VITE_APP_NAME=JS Notebook
