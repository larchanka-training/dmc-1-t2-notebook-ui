# Vite exposes only variables prefixed with VITE_ to browser code.

# API base URL for frontend requests.
# Local proxy mode can use /api/v1, direct local API can use http://127.0.0.1:8000/api/v1.
VITE_API_BASE_URL=/api/v1

# Environment marker for UI runtime/build diagnostics.
VITE_APP_ENV=dev

# Public application name displayed by the UI when needed.
VITE_APP_NAME=JS Notebook

# AI generation context mode (Epic 07 / #116). Unknown values fall back to at-send.
#   at-send   — (default) build context from the cells at generate time; nothing persisted.
#   persisted — load saved context on entry, rebuild async (debounced) on edits/deletes,
#               persist to the backend (/notebooks/{id}/ai-context); the send path waits.
#   PRIVACY: in `persisted` mode the cells' source is stored server-side. Avoid keeping
#   secrets (API keys, credentials) in cells when enabling it. `at-send` keeps context
#   ephemeral (sent only to the model at generate time).
VITE_AI_CONTEXT_MODE=at-send
