{
  "name": "ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "api:generate": "node scripts/api-gen.mjs",
    "api:check": "node scripts/api-gen.mjs --check",
    "api:vendor": "node scripts/api-vendor.mjs",
    "hooks:install": "lefthook install"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
